# Copy to `.env` and fill in. NEVER commit the real .env — it is gitignored.
# Every value below has a default; the ones marked REQUIRED have no useful one.

# ---------------------------------------------------------------- LLM
# Provider: groq | ollama | gemini. All three speak the OpenAI wire format.
#   groq   — free tier, fast, no card.      https://console.groq.com/keys
#   gemini — free tier.                     https://aistudio.google.com/apikey
#   ollama — fully local, no key, no cost. Needs `ollama serve` running.
llm_provider=groq

# REQUIRED for groq and gemini. Leave blank for ollama.
llm_api_key=

# Optional: blank uses the provider's default model.
#   groq   -> llama-3.3-70b-versatile
#   gemini -> gemini-2.0-flash
#   ollama -> orca-mini:latest
llm_model=

# Optional: blank uses the provider's default endpoint.
llm_base_url=

# ------------------------------------------------------------- GitHub
# REQUIRED. Fine-grained PAT for the watched repo, with read & write on
# Contents, Issues and Pull requests.
github_token=

# REQUIRED. The repo to watch, as owner/name (a full URL also works).
target_repo=your-username/docsentry-testbed

# Optional. An existing local checkout to analyse. Leave BLANK in production:
# the agent then clones target_repo itself, which is the only thing that works
# on a host with no sibling checkout.
local_repo_path=

# ------------------------------------------------------------ Webhook
# Must match the secret configured on the GitHub webhook.
webhook_secret=change-me-to-a-random-string

# Guards the endpoints with side effects (POST /api/analyze, DELETE /api/runs).
# While blank those endpoints are DISABLED — the service is internet-facing and
# an unauthenticated trigger would file real issues on your repo.
admin_token=

# ----------------------------------------------------------- Behaviour
# Review-first (default): never open a fix PR unprompted. Drift is reported as
# an issue with the exact fix DocSentry can apply; you approve it by commenting
# `/docsentry apply` (or `/docsentry dismiss`). Set false for full autonomy,
# where a high-confidence fix opens a PR directly.
require_approval=true

# confidence >= autofix_threshold  -> (autonomous mode) verify, then open a PR
# confidence >= alert_threshold    -> open an issue (a review issue when
#                                     require_approval is on)
# below both                       -> skip
autofix_threshold=0.85
alert_threshold=0.50

# Doc sections judged per code change. 1 keeps one drift to one issue.
max_docs_per_change=1

# bm25   — pure Python, no model download, deploys anywhere (default)
# chroma — dense vectors; needs `pip install docsentry[chroma]`
retrieval_backend=bm25

# true = analyse and report, but open no issues or PRs. Good for a first run.
dry_run=false

# Comma-separated dashboard origins. Set explicitly in production.
cors_origins=*
