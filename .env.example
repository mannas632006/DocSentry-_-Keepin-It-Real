# Copy this file to `.env` and fill in your own values.
# NEVER commit your real .env — it is gitignored for a reason.

# --- LLM (local Ollama, no API key needed) ---
divergence_model=orca-mini:latest

# --- GitHub ---
# Fine-grained PAT scoped to your target repo with Contents/Issues/PRs/Webhooks write.
github_token=github_pat_your_token_here
target_repo=your-username/docsentry-testbed
local_repo_path=../docsentry-testbed

# --- Webhook ---
webhook_secret=change-me-to-a-random-string

# --- Behavior thresholds ---
autofix_threshold=0.85
alert_threshold=0.50
