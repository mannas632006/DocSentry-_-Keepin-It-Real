# Copy to `.env.local` for development, or set in the Vercel project settings.
#
# Where the DocSentry API lives. Optional in every case:
#   - dev: defaults to http://localhost:8000
#   - served by the API itself (Docker image): defaults to the same origin
#   - Vercel: set this to your Render URL, or leave it unset and enter the URL
#     once in the dashboard's Settings panel (it is stored per browser).
#
# No trailing slash.
VITE_API_URL=https://docsentry-api.onrender.com
